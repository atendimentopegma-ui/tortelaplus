PORT=4173

# PostgreSQL obrigatorio na hospedagem. Cada cliente recebe schema proprio.
DATABASE_URL=postgresql://usuario:senha@host:5432/tortelaplus
PGSSL=require
PGPOOL_MAX=10

# Credenciais iniciais da Central da Rede. Troque antes da publicacao.
PEGMA_CENTRAL_USER=admin
PEGMA_CENTRAL_PASSWORD=troque-esta-senha

# Token alternativo para automacoes administrativas.
PEGMA_PROVIDER_TOKEN=

# Tempo maximo sem atividade antes de encerrar sessoes e liberar terminais.
PEGMA_SESSION_TTL_MINUTES=480

# Chave usada para criptografar senha do certificado e CSC no cofre fiscal.
PEGMA_SECRET_KEY=troque-por-uma-chave-segura-com-no-minimo-32-caracteres

# ACBrMonitor remoto, quando a API web estiver hospedada em Linux.
# Restrinja o acesso ao servidor Windows fiscal; nao exponha a porta publicamente.
PEGMA_ACBR_HOST=
PEGMA_ACBR_PORT=3436

# Alternativa recomendada quando a API SaaS esta na nuvem e o ACBr roda em Windows.
# O token e salvo criptografado por cliente nas Configuracoes do sistema.
# O agente deve expor GET /health e POST /fiscal/transmit somente via HTTPS.
PEGMA_ACBR_AGENT_URL=
PEGMA_ACBR_AGENT_TOKEN=

# Agente fiscal Windows separado. Use um token longo e restrinja a rede.
PEGMA_AGENT_HOST=127.0.0.1
PEGMA_AGENT_PORT=4180
PEGMA_AGENT_TOKEN=troque-por-um-token-longo
PEGMA_AGENT_RUNTIME=runtime/fiscal
PEGMA_AGENT_DATA=data/fiscal-agent

# Pasta externa sincronizada/armazenada fora do servidor para backups.
PEGMA_BACKUP_DIR=data/external-backups
PEGMA_BACKUP_INTERVAL_MINUTES=360
PEGMA_BACKUP_RETENTION_DAYS=30

# URLs de PIX, boleto e alertas sao configuradas por cliente no sistema.
# Tokens correspondentes ficam criptografados usando PEGMA_SECRET_KEY.
